---
import Button from '../forms/Button.astro';
import Badge from '../data/Badge.astro';
import Card from '../surface/Card.astro';

interface Props {
	href?: string;
	slug: string;
	title: string;
	summary: string;
	category?: string;
	featured?: boolean;
	publisherName: string;
	templateVersion?: string;
	priceModel?: string;
	badges?: string[];
}

const {
	href,
	slug,
	title,
	summary,
	category,
	featured = false,
	publisherName,
	templateVersion,
	priceModel,
	badges = [],
} = Astro.props as Props;

const cardHref = href ?? `/market/templates/${slug}/`;
const metaParts = [
	`Publisher: ${publisherName}`,
	templateVersion ? `v${templateVersion}` : undefined,
	priceModel ? priceModel.replaceAll('_', ' ') : undefined,
].filter(Boolean);
---

<Card
	eyebrow={featured ? `${category ?? 'Template'} · Featured` : category ?? 'Template'}
	title={title}
	description={summary}
	class="market-product-card"
>
	{badges.length > 0 ? (
		<div class="market-product-card__badges">
			{badges.map((badge) => <Badge tone="muted" size="sm">{badge}</Badge>)}
		</div>
	) : null}
	<p class="market-product-card__meta">{metaParts.join(' · ')}</p>
	<div slot="footer" class="market-product-card__footer">
		<Button href={cardHref} variant="secondary" size="sm">View details</Button>
	</div>
</Card>
