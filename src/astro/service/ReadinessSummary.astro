---
import ActionBar from '../layout/ActionBar.astro';
import EmptyState from '../surface/EmptyState.astro';
import Panel from '../surface/Panel.astro';
import StatusPill from '../data/StatusPill.astro';
import type { ReadinessSummaryViewModel, ReadinessStatus } from '../../lib/foundation/contracts.ts';
import type { Tone } from '../types.ts';

interface Props {
	viewModel: ReadinessSummaryViewModel;
	showAdvanced?: boolean;
	class?: string;
}

const {
	viewModel,
	showAdvanced = false,
	class: className,
} = Astro.props as Props;

const toneForStatus = (status: ReadinessStatus): Tone => {
	if (status === 'ready') return 'success';
	if (status === 'warning') return 'warning';
	if (status === 'blocked') return 'danger';
	return 'default';
};
const labelForStatus = (status: ReadinessStatus) => {
	if (status === 'ready') return 'Ready';
	if (status === 'warning') return 'Needs attention';
	if (status === 'blocked') return 'Blocked';
	return 'Unknown';
};
const items = viewModel.items.filter((item) => showAdvanced || !item.advanced);
---

<Panel class:list={['ts-readiness-summary', className]} title={viewModel.title} description={viewModel.description}>
	{items.length > 0 ? (
		<ul class="ts-readiness-list">
			{items.map((item) => (
				<li class="ts-readiness-item" data-status={item.status} data-advanced={item.advanced ? 'true' : 'false'}>
					<div class="ts-readiness-item__body">
						<StatusPill tone={toneForStatus(item.status)} label={labelForStatus(item.status)} />
						<div>
							<strong>{item.href ? <a href={item.href}>{item.label}</a> : item.label}</strong>
							<p>{item.message}</p>
						</div>
					</div>
					{item.action ? <ActionBar actions={[item.action]} /> : null}
				</li>
			))}
		</ul>
	) : (
		<EmptyState title={viewModel.emptyTitle ?? 'No readiness signals'} description={viewModel.emptyDescription} />
	)}
</Panel>
