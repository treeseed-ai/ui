---
import { getDocsDownloadForPath } from '../../utils/starlight-nav';

const { href, fileName = 'treeseed-book.md', title = 'Download book' } = Astro.props as {
	href?: string;
	fileName?: string;
	title?: string;
};
const download = href ? { downloadHref: href, downloadFileName: fileName, downloadTitle: title } : getDocsDownloadForPath(Astro.url.pathname);
---

{
	download && (
		<a
			href={download.downloadHref}
			download={download.downloadFileName}
			aria-label={download.downloadTitle}
			class="download-button docs-download-button print:hidden"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
				<polyline points="7 10 12 15 17 10" />
				<line x1="12" x2="12" y1="15" y2="3" />
			</svg>
			<span>Download Book</span>
		</a>
	)
}
