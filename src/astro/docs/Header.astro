---
import DesktopSidebarToggle from './DesktopSidebarToggle.astro';
import BookFontControls from './BookFontControls.astro';
import DownloadBook from './DownloadBook.astro';
import { SITE } from '../../utils/seo';

interface Props {
	hasSidebar?: boolean;
	hasToc?: boolean;
	showSearch?: boolean;
	contactHref?: string;
}

const {
	hasSidebar = false,
	hasToc = false,
	showSearch = true,
	contactHref = '/contact/',
} = Astro.props as Props;
---

<div class="header">
	<div class="title-wrapper sl-flex">
		<a class="ts-shell-brand" href="/">
			<span class="ts-shell-brand__mark">
				<img src={SITE.logo.src} alt={SITE.logo.alt} width="60" height="60" loading="eager" />
			</span>
			<span class="ts-shell-brand__text">
				<span class="ts-shell-brand__name">{SITE.name}</span>
				<span class="ts-shell-brand__tag">{SITE.statement}</span>
			</span>
		</a>
	</div>
	<div class="sl-hidden md:sl-flex print:hidden right-group">
		<div class="desktop-sidebar-toggles" aria-label="Reading controls">
			{hasSidebar && <DesktopSidebarToggle side="left" label="book contents" />}
			{hasToc && <DesktopSidebarToggle side="right" label="page contents" />}
		</div>
		<BookFontControls />
		{showSearch ? (
			<form class="docs-header-search" role="search">
				<label class="sr-only" for="docs-search">Search docs</label>
				<input id="docs-search" type="search" placeholder="Search docs" />
			</form>
		) : null}
		<DownloadBook />
		<div class="sl-flex social-icons">
			<a href={SITE.githubRepository} aria-label={`${SITE.name} GitHub repository`} class="contact-icon">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.1 6.8 9.5.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 2.9.8.1-.7.4-1.1.7-1.3-2.2-.3-4.6-1.1-4.6-4.9 0-1.1.4-2 1.1-2.7-.1-.3-.5-1.3.1-2.7 0 0 .9-.3 2.8 1a9.6 9.6 0 0 1 5.1 0c1.9-1.3 2.8-1 2.8-1 .6 1.4.2 2.4.1 2.7.7.7 1.1 1.6 1.1 2.7 0 3.8-2.3 4.6-4.6 4.9.4.3.7.9.7 1.8V21c0 .3.2.6.7.5A10 10 0 0 0 22 12c0-5.5-4.5-10-10-10Z" />
				</svg>
			</a>
			<a href={contactHref} aria-label={`Contact ${SITE.name}`} class="contact-icon">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M3.75 6.75h16.5v10.5H3.75z" />
					<path d="m4.5 7.5 7.5 6 7.5-6" />
				</svg>
			</a>
		</div>
	</div>
</div>

<style>
	@layer starlight.core {
		.header {
			display: flex;
			gap: var(--sl-nav-gap);
			justify-content: space-between;
			align-items: center;
			height: 100%;
			width: 100%;
		}

		.title-wrapper {
			overflow: clip;
			padding: 0.25rem;
			margin: -0.25rem;
			min-width: 0;
		}

		.right-group,
		.social-icons {
			align-items: center;
		}

		.right-group {
			margin-inline-start: auto;
			gap: 1.25rem;
			min-width: 0;
		}

		.desktop-sidebar-toggles {
			display: none;
		}

		.social-icons {
			gap: 1rem;
			flex: 0 0 auto;
		}

		.social-icons :global(a) {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 0.5rem;
			margin: 0;
			flex: 0 0 auto;
		}

		.contact-icon {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 2rem;
			height: 2rem;
			color: var(--sl-color-text);
		}

		.contact-icon:hover,
		.contact-icon:focus-visible {
			color: var(--sl-color-text-accent);
		}

		.contact-icon svg {
			width: 1.25rem;
			height: 1.25rem;
			fill: none;
			stroke: currentColor;
			stroke-width: 1.8;
			stroke-linecap: round;
			stroke-linejoin: round;
		}

		.social-icons::before {
			content: '';
			height: 2rem;
			border-inline-start: 1px solid var(--sl-color-gray-5);
			margin-inline-end: 0.25rem;
			flex: 0 0 auto;
		}

		:global(.docs-header-search) {
			margin-inline-start: auto;
			flex: 1 1 22rem;
		}

		@media (min-width: 50rem) {
			:global(:root[data-has-sidebar]) {
				--__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
			}
			:global(:root:not([data-has-toc])) {
				--__toc-width: 0rem;
			}
			.header {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				align-content: center;
			}
		}

		@media (min-width: 72rem) {
			.desktop-sidebar-toggles {
				display: inline-flex;
				align-items: center;
				gap: 0.65rem;
			}
		}
	}
</style>
