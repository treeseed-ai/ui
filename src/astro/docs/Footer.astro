---
import PublicFooter from '../shell/PublicFooter.astro';
import DevWatchReload from '../core/DevWatchReload.astro';

interface Props {
	lastUpdated?: string;
	editHref?: string;
	previous?: { label: string; href: string };
	next?: { label: string; href: string };
	showCredits?: boolean;
}

const {
	lastUpdated,
	editHref,
	previous,
	next,
	showCredits = true,
} = Astro.props as Props;
---

<div class="docs-footer-shell">
	<div class="docs-footer-page-band">
		<div class="docs-footer-page-inner">
			<div class="docs-footer-page-meta">
				{editHref ? <a href={editHref}>Edit this page</a> : <span></span>}
				{lastUpdated ? <p>Last updated {lastUpdated}</p> : null}
			</div>
			<nav class="pagination-links" aria-label="Docs pagination">
				{previous ? <a href={previous.href}>Previous: {previous.label}</a> : null}
				{next ? <a href={next.href}>Next: {next.label}</a> : null}
			</nav>
			{showCredits ? <p class="docs-footer-credits">Built for TreeSeed docs.</p> : null}
		</div>
	</div>

	<PublicFooter />
	<DevWatchReload />
</div>

<style>
	@layer starlight.core {
		.docs-footer-shell {
			margin-top: 4rem;
			width: 100%;
		}

		.docs-footer-page-inner,
		.docs-footer-shell :global(.ts-public-footer__inner) {
			width: min(100%, var(--ts-content-width));
			margin-inline: auto;
			padding-inline: 1rem;
		}

		.docs-footer-page-band {
			padding-bottom: 2.5rem;
		}

		.docs-footer-page-inner {
			display: grid;
			gap: 1.5rem;
		}

		:global(:root[data-docs-book-page='true']) .docs-footer-page-inner {
			max-width: var(--docs-book-panel-width);
		}

		:global(:root[data-docs-book-page='true']) .docs-footer-page-inner .pagination-links > :only-child {
			max-width: min(28rem, 100%);
			margin-inline: auto;
		}

		.docs-footer-page-meta {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem 3rem;
			justify-content: space-between;
			margin-top: 3rem;
			font-size: var(--sl-text-sm);
			color: var(--sl-color-gray-3);
		}

		.docs-footer-page-meta :global(p:only-child) {
			margin-inline-start: auto;
		}

		.docs-footer-credits {
			margin: 0 auto;
			font-size: var(--sl-text-xs);
			color: var(--sl-color-gray-3);
		}

		.docs-footer-credits a {
			color: inherit;
			text-decoration: none;
		}

		.docs-footer-credits a:hover,
		.docs-footer-credits a:focus-visible {
			color: var(--sl-color-white);
		}

		.docs-footer-shell :global(.ts-public-footer) {
			margin-top: 0;
		}

		@media (min-width: 40rem) {
			.docs-footer-page-inner,
			.docs-footer-shell :global(.ts-public-footer__inner) {
				padding-inline: 1.5rem;
			}
		}

		@media (min-width: 64rem) {
			.docs-footer-page-inner,
			.docs-footer-shell :global(.ts-public-footer__inner) {
				padding-inline: 2rem;
			}
		}
	}
</style>
