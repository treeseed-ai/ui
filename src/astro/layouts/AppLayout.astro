---
import '../../styles/app-controls.css';
import '../../styles/operations.css';
import AppShell from '../shell/AppShell.astro';
import DeleteConfirmationModal from '../app/controls/DeleteConfirmationModal.astro';
import SensitiveDataUnlock from '../app/sensitive/SensitiveDataUnlock.astro';
import type { ThemePreference } from '../../theme/types.ts';


interface TeamEntry {
	id: string;
	name: string;
	slug?: string;
	displayName?: string | null;
}

interface Props {
	title: string;
	description?: string;
	currentPath: string;
	teams: TeamEntry[];
	activeTeam?: TeamEntry | null;
	showSensitiveUnlock?: boolean;
	appearance?: ThemePreference;
	navItems?: Array<{ label: string; href: string }>;
	quickActions?: Array<{ label: string; href: string; variant?: 'primary' | 'secondary' | 'ghost' | 'danger'; reload?: boolean }>;
	appearanceEndpoint?: string;
}

const {
	title,
	description = 'Set up teams, hosts, projects, capacity, work, and knowledge.',
	currentPath,
	teams,
	activeTeam = null,
	showSensitiveUnlock: forceSensitiveUnlock = false,
	appearance = { scheme: 'fern', mode: 'system' },
	navItems: providedNavItems,
	quickActions: providedQuickActions,
	appearanceEndpoint = '/v1/auth/web/appearance',
} = Astro.props as Props;

const railItems = providedNavItems ?? [
	{ label: 'Start', href: '/app/' },
	{ label: 'Hosts', href: '/app/hosts' },
	{ label: 'Projects', href: '/app/projects' },
	{ label: 'Capacity', href: '/app/capacity/providers' },
	{ label: 'Work', href: '/app/work/objectives' },
	{ label: 'Knowledge', href: '/app/knowledge/artifacts' },
];

const quickActions = providedQuickActions ?? [
	activeTeam
		? { label: 'New project', href: '/app/projects/new', variant: 'primary' as const }
		: { label: 'New team', href: '/app/teams/new', variant: 'primary' as const },
	{ label: 'Account', href: '/app/account', variant: 'secondary' as const },
	{ label: 'Sign out', href: '/v1/auth/logout?returnTo=/', variant: 'secondary' as const, reload: true },
];
const teamOptions = teams.map((team) => ({
	id: team.id,
	label: team.displayName ?? team.name ?? team.slug ?? team.id,
}));
const sensitiveUnlockPaths = [
	'/app/hosts',
	'/app/projects/new',
	'/app/capacity/providers/new',
];
const routePath = Astro.url.pathname;
const showSensitiveUnlock = sensitiveUnlockPaths.some((path) => (
	currentPath === path
	|| currentPath.startsWith(`${path}/`)
	|| routePath === path
	|| routePath.startsWith(`${path}/`)
)) || forceSensitiveUnlock;
---

<AppShell
	title={title}
	description={description}
	currentPath={currentPath}
	appearance={appearance}
	brand={{
		name: 'TreeSeed Platform',
		tag: 'Simple controls',
		href: '/app/',
		logoSrc: '/logo.svg',
		logoAlt: '',
	}}
	navItems={railItems}
	quickActions={quickActions}
>
	<div slot="railContext" class="ts-team-switcher">
		<div class="ts-section__eyebrow">Team</div>
		{teams.length > 0 ? (
			<form class="ts-team-selector" aria-label="Active team" data-team-switcher>
				<label class="ts-field ts-team-selector__label">
					<select class="ts-control" name="teamId" aria-label="Active team">
						{teamOptions.map((team) => (
							<option value={team.id} selected={team.id === activeTeam?.id}>{team.label}</option>
						))}
					</select>
				</label>
				<a class="ts-icon-button" href="/app/teams" title="Manage teams" aria-label="Manage teams">Manage</a>
			</form>
		) : (
			<a class="ts-create-team-button" href="/app/teams/new">Create team</a>
		)}
	</div>
	{showSensitiveUnlock ? <SensitiveDataUnlock part="button" slot="headerAction" /> : null}
	<slot />
	{showSensitiveUnlock ? <SensitiveDataUnlock part="modal" slot="sensitiveModal" /> : null}
	<DeleteConfirmationModal slot="modal" />
</AppShell>

<script>
	document.querySelectorAll('[data-team-switcher]').forEach((form) => {
		const select = (form as HTMLFormElement).elements.namedItem('teamId') as HTMLSelectElement | null;
		select?.addEventListener('change', () => {
			const url = new URL(window.location.href);
			url.searchParams.delete('teamId');
			document.cookie = `treeseed_active_team=${encodeURIComponent(select.value)}; path=/app; max-age=31536000; SameSite=Lax`;
			window.location.href = url.toString();
		});
	});
</script>

<script is:inline data-astro-rerun define:vars={{ appearanceEndpoint }}>
	(() => {
		const bindingKey = '__treeseedAuthenticatedAppearanceSyncBound';
		if (window[bindingKey]) return;
		window[bindingKey] = true;

		window.addEventListener('treeseed:theme-change', (event) => {
			const detail = event.detail || {};
			if (detail.persist !== true || !detail.scheme || !detail.mode) return;
	fetch(appearanceEndpoint, {
				method: 'PATCH',
				headers: { accept: 'application/json', 'content-type': 'application/json' },
				body: JSON.stringify({ colorScheme: detail.scheme, themeMode: detail.mode }),
				keepalive: true,
			}).catch(() => {
				// Local cookies already carry the immediate preference; the next change can retry persistence.
			});
		});
	})();
</script>
