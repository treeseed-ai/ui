---
import Button from '../../forms/Button.astro';
import Field from '../../forms/Field.astro';
import Select from '../../forms/Select.astro';
import TextInput from '../../forms/TextInput.astro';
import FormActions from '../../forms/FormActions.astro';
import MarkdownField from './MarkdownField.astro';
import ContentFieldHelp from './ContentFieldHelp.astro';

const WORK_CONTENT_LABELS: Record<string, { singular: string; plural: string; title: string }> = {
	objectives: { singular: 'objective', plural: 'objectives', title: 'Objectives' },
	questions: { singular: 'question', plural: 'questions', title: 'Questions' },
	proposals: { singular: 'proposal', plural: 'proposals', title: 'Proposals' },
	decisions: { singular: 'decision', plural: 'decisions', title: 'Decisions' },
	notes: { singular: 'note', plural: 'notes', title: 'Notes' },
};

const FIELD_HELP: Record<string, { label: string; purpose: string; example?: string }> = {
	title: { label: 'Title', purpose: 'A short, scannable name for the related record.' },
	slug: { label: 'Slug', purpose: 'An optional URL-safe identifier. Leave blank to generate one from the title.' },
	status: { label: 'Status', purpose: 'Where this record sits in the current workflow.' },
	description: { label: 'Description', purpose: 'A concise description of the record and its purpose.' },
	summary: { label: 'Summary', purpose: 'A brief reader-facing summary.' },
	rationale: { label: 'Rationale', purpose: 'Why this decision was made.' },
	motivation: { label: 'Motivation', purpose: 'Why this work matters now.' },
	author: { label: 'Author', purpose: 'The person or agent credited for the note.' },
	body: { label: 'Body', purpose: 'The full Markdown body for the related record.' },
	timeHorizon: { label: 'Horizon', purpose: 'The expected planning horizon for the objective.' },
	questionType: { label: 'Question type', purpose: 'The kind of question being captured.' },
	proposalType: { label: 'Proposal type', purpose: 'The kind of proposal being captured.' },
	decisionType: { label: 'Decision type', purpose: 'The kind of decision outcome.' },
};

interface Props {
	projectId: string;
	parentCollection: string;
	parentSlug: string;
	parentTitle: string;
	actions: Array<{ collection: string; label: string }>;
}

const {
	projectId,
	parentCollection,
	parentSlug,
	parentTitle,
	actions,
} = Astro.props as Props;

const contentLabels = WORK_CONTENT_LABELS;
const json = JSON.stringify({ projectId, parentCollection, parentSlug }).replace(/</gu, '\\u003c');
const statusOptions = [
	{ label: 'Planned', value: 'planned' },
	{ label: 'Live', value: 'live' },
	{ label: 'In progress', value: 'in progress' },
	{ label: 'Exploratory', value: 'exploratory' },
	{ label: 'Speculative', value: 'speculative' },
];
const typeOptions: Record<string, Array<{ label: string; value: string }>> = {
	objectives: [{ label: 'Near-term', value: 'near-term' }, { label: 'Mid-term', value: 'mid-term' }, { label: 'Long-term', value: 'long-term' }],
	questions: [{ label: 'Strategy', value: 'strategy' }, { label: 'Implementation', value: 'implementation' }, { label: 'Research', value: 'research' }, { label: 'Evaluation', value: 'evaluation' }],
	proposals: [{ label: 'Implementation', value: 'implementation' }, { label: 'Strategy', value: 'strategy' }, { label: 'Policy', value: 'policy' }, { label: 'Research', value: 'research' }],
	decisions: [{ label: 'Approved', value: 'approved' }, { label: 'Rejected', value: 'rejected' }, { label: 'Deferred', value: 'deferred' }, { label: 'Request changes', value: 'request_changes' }, { label: 'Superseded', value: 'superseded' }],
};
const typeField: Record<string, { name: string; label: string }> = {
	objectives: { name: 'timeHorizon', label: 'Horizon' },
	questions: { name: 'questionType', label: 'Question type' },
	proposals: { name: 'proposalType', label: 'Proposal type' },
	decisions: { name: 'decisionType', label: 'Decision type' },
};
function help(name: string) {
	return FIELD_HELP[name] ?? { label: name, purpose: '' };
}
---

{actions.length > 0 ? (
	<section class="ts-related-create" aria-label="Create related content" data-related-create>
		<div class="ts-related-create__header">
			<div>
				<p class="ts-section__eyebrow">Related content</p>
				<h2>Create while viewing this record</h2>
				<p>Add linked content without leaving <strong>{parentTitle}</strong>. TreeSeed saves the relation on both records.</p>
			</div>
			<div class="ts-related-create__actions">
				{actions.map((action) => (
					<Button type="button" variant="secondary" size="sm" class="ts-related-create__button" ariaLabel={action.label}>
						<span data-related-create-open={action.collection}>{action.label}</span>
					</Button>
				))}
			</div>
		</div>
		<div class="ts-related-float" data-related-float hidden>
			<div class="ts-related-float__window" data-related-window>
				<header class="ts-related-float__bar" data-related-drag-handle>
					<div>
						<p class="ts-section__eyebrow">Create related content</p>
						<h2 data-related-title>New related content</h2>
					</div>
					<button class="ts-icon-button" type="button" data-related-close aria-label="Cancel related content creation">Cancel</button>
				</header>
				<div class="ts-related-float__body">
					{actions.map((action) => {
						const label = contentLabels[action.collection]?.singular ?? 'record';
						const type = typeField[action.collection];
						return (
							<form class="ts-form-stack ts-related-form" data-related-form={action.collection} hidden>
								<input type="hidden" name="targetCollection" value={action.collection} />
								<input type="hidden" name="parentCollection" value={parentCollection} />
								<input type="hidden" name="parentSlug" value={parentSlug} />
								<div class="ts-form-grid">
									<Field label="Title" name={`related-${action.collection}-title`} required>
										<div class="ts-help-row">
											<TextInput name="title" required />
											<ContentFieldHelp {...help('title')} />
										</div>
									</Field>
									<Field label="Slug" name={`related-${action.collection}-slug`}>
										<div class="ts-help-row">
											<TextInput name="slug" placeholder="Generated from title if empty" />
											<ContentFieldHelp {...help('slug')} />
										</div>
									</Field>
									<Field label="Status" name={`related-${action.collection}-status`}>
										<div class="ts-help-row">
											<Select name="status" options={statusOptions} />
											<ContentFieldHelp {...help('status')} />
										</div>
									</Field>
									{type ? (
										<Field label={type.label} name={`related-${action.collection}-${type.name}`}>
											<div class="ts-help-row">
												<Select name={type.name} options={typeOptions[action.collection] ?? []} />
												<ContentFieldHelp {...help(type.name)} />
											</div>
										</Field>
									) : null}
								</div>
								<MarkdownField label="Description" name="description" rows={3} required help={help('description').purpose} />
								<MarkdownField label="Summary" name="summary" rows={3} help={help('summary').purpose} />
								{action.collection === 'decisions' ? (
									<MarkdownField label="Rationale" name="rationale" rows={4} help={help('rationale').purpose} />
								) : action.collection !== 'notes' ? (
									<MarkdownField label="Motivation" name="motivation" rows={4} help={help('motivation').purpose} />
								) : (
									<Field label="Author" name={`related-${action.collection}-author`}>
										<div class="ts-help-row">
											<TextInput name="author" value="market-steward" />
											<ContentFieldHelp {...help('author')} />
										</div>
									</Field>
								)}
								<MarkdownField label="Body" name="body" rows={8} help={help('body').purpose} />
								<FormActions align="start">
									<Button type="submit">Create related {label}</Button>
									<Button type="button" variant="secondary" class="ts-related-cancel">Cancel</Button>
									<span class="ts-subtle" data-related-status role="status"></span>
								</FormActions>
							</form>
						);
					})}
				</div>
			</div>
		</div>
		<script is:inline type="application/json" id="related-content-data" set:html={json}></script>
	</section>
) : null}

<script>
	import '../../../lib/app/markdown-field.ts';
	import '../../../lib/app/related-content-creator.ts';
</script>
