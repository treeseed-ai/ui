---
type RequirementSummary = {
	hosts?: unknown[];
	resources?: unknown[];
	secrets?: unknown[];
};

interface Props {
	templates: Array<{ slug: string; sourceRef?: string; title: string; launchRequirements?: RequirementSummary }>;
	defaultTemplateId: string;
}

const { templates, defaultTemplateId } = Astro.props;
const defaultTemplate = templates.find((template) => (template.sourceRef ?? template.slug) === defaultTemplateId) ?? templates[0];
const hostCount = defaultTemplate?.launchRequirements?.hosts?.length ?? 0;
const resourceCount = defaultTemplate?.launchRequirements?.resources?.length ?? 0;
const secretCount = defaultTemplate?.launchRequirements?.secrets?.length ?? 0;
---

<div class="ts-launch-requirement-summary" data-launch-requirement-summary>
	<div>
		<strong data-requirement-summary-template>{defaultTemplate?.title ?? 'Selected template'}</strong>
		<span data-requirement-summary-counts>{hostCount} hosts · {resourceCount} resources · {secretCount} secrets</span>
	</div>
	<p data-requirement-summary-detail>Requirements are loaded from the selected template and resolved against team defaults, managed hosts, or inline host creation.</p>
</div>
