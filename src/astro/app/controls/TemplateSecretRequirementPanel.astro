---

type ProjectLaunchSecretRequirementViewModel = {
	key: string;
	env: string;
	source: string;
	required: boolean;
	sensitivity: string;
	targets: string[];
};

interface Props {
	requirement: ProjectLaunchSecretRequirementViewModel;
}

const { requirement } = Astro.props;
const targets = requirement.targets.map((target) => String(target));
---

<section
	class="ts-inline-host-card ts-template-secret-requirement"
	data-requirement-card
	data-requirement-kind="secret"
	data-requirement-key={requirement.key}
	data-requirement-type="secret"
	data-requirement-required={String(requirement.required)}
>
	<div class="ts-inline-host-card__header">
		<strong data-requirement-title>{requirement.env}</strong>
		<span data-requirement-purpose>Secret source: {requirement.source}</span>
	</div>
	<div class="ts-requirement-meta" aria-label={`${requirement.env} secret requirement details`}>
		<span data-requirement-required-label>{requirement.required ? 'Required' : 'Optional'}</span>
		<span data-requirement-provider>{requirement.sensitivity}</span>
		<span data-requirement-readiness>Metadata preview only</span>
	</div>
	<div class="ts-requirement-preview" data-requirement-preview>
		<div>
			<strong>Targets</strong>
			<span data-config-preview>{targets.length > 0 ? targets.join(' · ') : 'No targets declared'}</span>
		</div>
		<div>
			<strong>Values</strong>
			<span data-secret-preview>No secret values shown or written here</span>
		</div>
	</div>
</section>
