---
interface Props {
	projectId: string;
	current: 'settings' | 'hosts' | 'deploy' | 'guidance' | 'decisions' | 'workdays' | 'agents' | 'artifacts' | 'delete';
}
const { projectId, current } = Astro.props as Props;
const encoded = encodeURIComponent(projectId);
const items = [
	{ key: 'settings', label: 'Settings', href: `/app/projects/${encoded}/settings` },
	{ key: 'deploy', label: 'Deploy', href: `/app/projects/${encoded}/deploy` },
	{ key: 'guidance', label: 'Guidance', href: `/app/projects/${encoded}/guidance` },
	{ key: 'decisions', label: 'Decisions', href: `/app/projects/${encoded}/decisions` },
	{ key: 'workdays', label: 'Workdays', href: `/app/projects/${encoded}/workdays` },
	{ key: 'agents', label: 'Agents', href: `/app/projects/${encoded}/agents` },
	{ key: 'artifacts', label: 'Artifacts', href: `/app/projects/${encoded}/artifacts` },
	{ key: 'delete', label: 'Delete', href: `/app/projects/${encoded}/delete` },
];
---

<nav class="ts-tabs" aria-label="Project controls">
	{items.map((item) => (
		<a class="ts-tab" href={item.href} aria-current={item.key === current ? 'page' : undefined}>{item.label}</a>
	))}
</nav>
