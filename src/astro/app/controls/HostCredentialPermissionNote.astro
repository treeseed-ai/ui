---
type HostPermissionProfile = {
	title: string;
	summary: string;
	sections: Array<{ label: string; items: string[] }>;
	footer?: string;
};

interface Props {
	hostType: string;
}

const hostType = String(Astro.props.hostType ?? '').trim();
const profiles: Record<string, HostPermissionProfile> = {
	repository: {
		title: 'GitHub token permissions',
		summary: 'Use a fine-grained token or GitHub App credential for the selected owner.',
		sections: [
			{ label: 'Owner access', items: ['Create repositories for the owner'] },
			{ label: 'Repository access', items: ['Contents read/write', 'Actions and workflows read/write', 'Environments read/write', 'Secrets and variables read/write'] },
			{ label: 'Collaboration', items: ['Pull requests read/write', 'Issues read/write'] },
		],
	},
	web: {
		title: 'Cloudflare API token permissions',
		summary: 'Use an account-level token for the Cloudflare account and root domain this host manages.',
		sections: [
			{ label: 'Account resources', items: ['Pages Write', 'Workers Scripts Write', 'Workers KV Storage Write', 'Workers R2 Storage Write', 'D1 Write', 'Queues Write', 'Turnstile Sites Write'] },
			{ label: 'Rules and cache', items: ['Account Rulesets Write', 'Account Rule Lists Write', 'Cache Settings Write for the target zone'] },
			{ label: 'Target domain', items: ['Zone Read', 'DNS Write', 'SSL and Certificates Write'] },
			{ label: 'Optional AI', items: ['AI Gateway Run and Workers AI Write when the project uses AI gateway or model execution'] },
		],
		footer: 'Cloudflare API docs call Cache Settings the Cache Rules permission, and Account Rule Lists the Account Filter Lists permission.',
	},
	email: {
		title: 'SMTP credential requirements',
		summary: 'Use a mailbox, app password, or provider credential dedicated to transactional project email.',
		sections: [
			{ label: 'Sending access', items: ['Authenticated SMTP send permission', 'Permission to send from the configured From address', 'Reply-to address allowed by the provider policy'] },
			{ label: 'Transport', items: ['STARTTLS or TLS on the selected port', 'Provider account allows app or service credentials'] },
		],
		footer: 'TreeSeed stores these credentials for project secret sync, but does not add an email-provider secret manager.',
	},
	'capacity-provider': {
		title: 'Railway API token permissions',
		summary: 'Use a Railway token scoped to the workspace that will own capacity provider services.',
		sections: [
			{ label: 'Workspace access', items: ['Create or manage projects and services', 'Link services to the selected workspace or project', 'Read deployment status and logs'] },
			{ label: 'Runtime configuration', items: ['Set service variables', 'Deploy services', 'Manage service domains when provider setup needs them'] },
		],
	},
	ai: {
		title: 'AI provider key requirements',
		summary: 'Use a provider key intended for team automation, not a personal throwaway key.',
		sections: [
			{ label: 'Model access', items: ['Access to the configured default model', 'Permission for chat, response, or completion endpoints used by the provider'] },
			{ label: 'Operational limits', items: ['Sufficient quota for agent and content workflows', 'Base URL and organization/project scope match the selected provider account'] },
		],
	},
};
const profile = profiles[hostType];
---

{profile ? (
	<div class="ts-permission-note ts-host-permission-note" data-host-permission-note={hostType}>
		<div class="ts-host-permission-note__header">
			<span>Credential requirements</span>
			<strong>{profile.title}</strong>
		</div>
		<p>{profile.summary}</p>
		<div class="ts-host-permission-note__sections">
			{profile.sections.map((section) => (
				<section>
					<span>{section.label}</span>
					<ul>
						{section.items.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			))}
		</div>
		{profile.footer ? <p class="ts-host-permission-note__footer">{profile.footer}</p> : null}
	</div>
) : null}
