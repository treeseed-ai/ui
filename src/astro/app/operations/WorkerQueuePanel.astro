---
import ActionList from '../../data/ActionList.astro';
import Panel from '../../surface/Panel.astro';

interface Props {
	workers: any[];
}

const { workers } = Astro.props as Props;
---

<Panel eyebrow="Workers" title="Workers and queues" description="Runtime execution state belongs here, outside the primary workflow.">
	<ActionList items={workers.map((item) => ({
		title: item.title,
		description: item.description,
		href: item.href,
		meta: item.meta,
		tone: item.tone,
		actionLabel: item.href ? 'Inspect' : undefined,
	}))}>
		<p class="ts-empty-inline">No workers or queued operational tasks are visible.</p>
	</ActionList>
</Panel>
