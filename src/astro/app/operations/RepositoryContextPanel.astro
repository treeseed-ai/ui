---
import ActionList from '../../data/ActionList.astro';
import Panel from '../../surface/Panel.astro';

interface Props {
	repositories?: any[];
}

const { repositories = [] } = Astro.props as Props;
---

<Panel eyebrow="Repository Context" title="Operational context sources" description="Repositories are shown as context for decisions, artifacts, and execution history.">
	<ActionList items={repositories.map((repository) => ({
	title: [repository.owner, repository.name ?? repository.role].filter(Boolean).join('/') || repository.title || 'Repository',
	description: repository.description ?? `${repository.projectName ?? 'Operational context'} - ${repository.status ?? 'connected'}`,
		href: repository.href,
		meta: repository.role ?? repository.meta ?? 'repository',
		tone: repository.tone ?? 'default',
		actionLabel: repository.href ? 'Open' : undefined,
	}))}>
		<p class="ts-empty-inline">No repository context has been recorded yet.</p>
	</ActionList>
</Panel>
