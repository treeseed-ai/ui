---
import ActionList from '../../data/ActionList.astro';
import Panel from '../../surface/Panel.astro';

interface Props {
	seeds: any[];
}

const { seeds } = Astro.props as Props;
---

<Panel eyebrow="Seeds" title="Environment seed operations" description="Seed plans, approvals, and runs are operator controls, not primary navigation.">
	<ActionList items={seeds.map((item) => ({
		title: item.title,
		description: item.description,
		href: item.href,
		meta: item.meta,
		tone: item.tone,
		actionLabel: item.href ? 'Inspect' : undefined,
	}))}>
		<p class="ts-empty-inline">No seed plan or run state is visible.</p>
	</ActionList>
</Panel>
