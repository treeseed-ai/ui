---
import Badge from '../../data/Badge.astro';
import Panel from '../../surface/Panel.astro';

interface Props {
	approval: any;
	options?: any[];
	action?: string;
}

const {
	approval,
	options = [],
	action = `/v1/ui/governance/${encodeURIComponent(approval?.approvalId ?? approval?.id ?? '')}/decision`,
} = Astro.props as Props;
const pending = ['pending', 'waiting_for_approval', 'under_review', 'approval_required'].includes(String(approval?.state ?? '').toLowerCase());
---

<Panel eyebrow="Approval request" title="Review request" description="Approve or reject this operational request with a short note.">
	<div class="ts-governance-decision">
		<div class="ts-governance-decision__state">
			<Badge tone={approval?.tone ?? 'default'}>{approval?.state ?? 'recorded'}</Badge>
			<span>{approval?.severity ?? 'moderate'} severity</span>
		</div>
		{pending ? (
			<form method="post" action={action} class="ts-governance-decision__form">
				<label>
					<span>Approval note</span>
					<textarea name="note" rows="4" placeholder="Record the operational rationale for this approval."></textarea>
				</label>
				<div class="ts-governance-decision__actions">
					{(options.length > 0 ? options : [
						{ id: 'approve', label: 'Approve', state: 'approved' },
						{ id: 'reject', label: 'Reject', state: 'rejected' },
					]).map((option) => (
						<button class="ts-button" data-variant={option.state === 'rejected' ? 'danger' : 'primary'} type="submit" name="optionId" value={option.id}>{option.label}</button>
					))}
				</div>
			</form>
		) : (
			<p class="ts-empty-inline">This request has already been reviewed.</p>
		)}
	</div>
</Panel>

<script>
	document.querySelectorAll<HTMLFormElement>('.ts-governance-decision__form').forEach((form) => {
		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			const submitter = event.submitter as HTMLButtonElement | null;
			const formData = new FormData(form);
			if (submitter?.name) formData.set(submitter.name, submitter.value);
			const response = await fetch(form.action, {
				method: 'POST',
				headers: { accept: 'application/json', 'content-type': 'application/json' },
				body: JSON.stringify(Object.fromEntries(formData.entries())),
			});
			if (response.ok) {
				location.reload();
				return;
			}
			const envelope = await response.json().catch(() => null);
			alert(envelope?.error ?? 'Approval could not be recorded.');
		});
	});
</script>
