---
import ActionList from '../../data/ActionList.astro';
import Panel from '../../surface/Panel.astro';

interface Props {
	title?: string;
	description?: string;
	policies?: any[];
	constraints?: any[];
}

const {
	title = 'Policies and constraints',
	description = 'Human-readable approval rules, budget thresholds, and operational constraints.',
	policies = [],
	constraints = [],
} = Astro.props as Props;
const items = [
	...policies.map((policy) => ({
		title: policy.title,
		description: policy.description,
		href: policy.href,
		meta: policy.meta ?? policy.policyType,
		tone: policy.tone,
		actionLabel: policy.href ? 'Open' : undefined,
	})),
	...constraints.map((constraint) => ({
		title: constraint.title,
		description: constraint.description,
		href: constraint.href,
		meta: constraint.meta ?? constraint.constraintType,
		tone: constraint.tone,
		actionLabel: constraint.href ? 'Open' : undefined,
	})),
];
---

<Panel eyebrow="Policy" title={title} description={description}>
	<ActionList items={items}>
		<p class="ts-empty-inline">No governance policies or constraints are visible for this context.</p>
	</ActionList>
</Panel>
