---
import StatusPill from '../../data/StatusPill.astro';
import EmptyState from '../../surface/EmptyState.astro';

interface Props {
	events?: any[];
	phases?: any[];
	emptyTitle?: string;
	emptyDescription?: string;
}

const {
	events = [],
	phases = [],
	emptyTitle = 'No operational events recorded',
	emptyDescription = 'Events will appear as work moves through execution, governance, and knowledge production.',
} = Astro.props as Props;

const phaseOrder = ['research', 'implementation', 'verification', 'governance', 'knowledge'];
const fallbackPhases = phaseOrder.map((key) => ({
	key,
	label: key.replace(/^\w/u, (letter) => letter.toUpperCase()),
	description: '',
	state: 'waiting',
	tone: 'muted',
}));
const timelinePhases = (phases.length > 0 ? phases : fallbackPhases)
	.filter((phase) => phaseOrder.includes(phase.key))
	.sort((left, right) => phaseOrder.indexOf(left.key) - phaseOrder.indexOf(right.key))
	.map((phase) => ({
		...phase,
		domId: String(phase.key).replace(/[^a-z0-9_-]/giu, '-'),
		events: events.filter((event) => (event.phase ?? event.category ?? 'implementation') === phase.key),
	}));
---

{events.length > 0 ? (
	<div class="ts-operational-timeline" aria-label="Operational timeline">
		{timelinePhases.map((phase) => (
			<section class="ts-operational-timeline__phase" data-phase={phase.key} data-state={phase.state ?? 'waiting'} aria-labelledby={`timeline-phase-${phase.domId}`} aria-describedby={phase.description ? `timeline-phase-${phase.domId}-description` : undefined}>
				<div class="ts-operational-timeline__phase-header">
					<div>
						<p class="ts-operational-timeline__category">Operational phase</p>
						<h3 id={`timeline-phase-${phase.domId}`}>{phase.label}</h3>
						{phase.description ? <p id={`timeline-phase-${phase.domId}-description`}>{phase.description}</p> : null}
						<span class="ts-sr-only">{phase.events.length} recorded event{phase.events.length === 1 ? '' : 's'} in this phase.</span>
					</div>
					<StatusPill tone={phase.tone ?? 'default'}>{phase.state ?? 'waiting'}</StatusPill>
				</div>
				{phase.events.length > 0 ? (
					<ol class="ts-operational-timeline__items" aria-label={`${phase.label} events`}>
						{phase.events.map((event: any, index: number) => (
							<li class="ts-operational-timeline__item" data-category={event.category ?? 'execution'} aria-label={`${phase.label} event ${index + 1}: ${event.title}`}>
								<div class="ts-operational-timeline__marker" aria-hidden="true"></div>
								<div class="ts-operational-timeline__content">
									<div class="ts-operational-timeline__header">
										<div>
											<p class="ts-operational-timeline__category">{event.category ?? 'event'}</p>
											<h4>{event.href ? <a href={event.href}>{event.title}</a> : event.title}</h4>
										</div>
										<StatusPill tone={event.tone ?? 'default'}>{event.state ?? event.meta ?? 'recorded'}</StatusPill>
									</div>
									{event.description ? <p>{event.description}</p> : null}
									<div class="ts-operational-timeline__meta">
										{event.timestamp ? <time>{event.timestamp}</time> : null}
										{event.meta ? <span>{event.meta}</span> : null}
										{Array.isArray(event.repositoryRefs) && event.repositoryRefs.length > 0 ? <span>{event.repositoryRefs.length} repository reference{event.repositoryRefs.length === 1 ? '' : 's'}</span> : null}
										{Array.isArray(event.artifactRefs) && event.artifactRefs.length > 0 ? <span>{event.artifactRefs.length} artifact reference{event.artifactRefs.length === 1 ? '' : 's'}</span> : null}
									</div>
								</div>
							</li>
						))}
					</ol>
				) : (
					<p class="ts-empty-inline">No events recorded for this phase yet.</p>
				)}
			</section>
		))}
	</div>
) : (
	<EmptyState title={emptyTitle} description={emptyDescription} />
)}
