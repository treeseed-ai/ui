---
interface Props {
	part?: 'button' | 'modal';
}

const { part = 'modal' } = Astro.props as Props;
---

{part === 'button' ? (
	<button class="ts-sensitive-lock-button" type="button" data-sensitive-unlock-button data-state="locked" aria-haspopup="dialog" aria-controls="sensitive-unlock-modal">
		<span class="ts-sensitive-lock-button__icons" aria-hidden="true">
			<svg data-sensitive-lock-icon="locked" viewBox="0 0 24 24" focusable="false">
				<path d="M7 10V8a5 5 0 0 1 10 0v2h1a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h1Zm2 0h6V8a3 3 0 0 0-6 0v2Zm3 4.25a1.25 1.25 0 0 0-.65 2.32V18h1.3v-1.43A1.25 1.25 0 0 0 12 14.25Z" />
			</svg>
			<svg data-sensitive-lock-icon="unlocked" viewBox="0 0 24 24" focusable="false">
				<path d="M9 10h9a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h1V8a5 5 0 0 1 9.5-2.18l-1.8.88A3 3 0 0 0 9 8v2Zm3 4.25a1.25 1.25 0 0 0-.65 2.32V18h1.3v-1.43A1.25 1.25 0 0 0 12 14.25Z" />
			</svg>
		</span>
		<span data-sensitive-unlock-label>Unlock sensitive data</span>
	</button>
) : null}

{part === 'modal' ? (
<>
	<div class="ts-sensitive-modal" id="sensitive-unlock-modal" data-sensitive-modal hidden>
		<div class="ts-sensitive-modal__scrim" data-sensitive-modal-close></div>
		<section class="ts-sensitive-dialog" role="dialog" aria-modal="true" aria-labelledby="sensitive-unlock-title">
			<div class="ts-sensitive-dialog__main">
				<div class="ts-panel__header">
					<div>
						<p class="ts-section__eyebrow">Sensitive Data</p>
						<h2 id="sensitive-unlock-title">Unlock encrypted team data</h2>
						<p>One passphrase unlocks host credentials and sensitive actions on this page until refresh or navigation.</p>
					</div>
					<button class="ts-icon-button" type="button" data-sensitive-modal-close aria-label="Close sensitive data unlock">Close</button>
				</div>
				<div class="ts-tabs" role="tablist" aria-label="Sensitive data modes">
					<button class="ts-tab" type="button" role="tab" data-sensitive-modal-mode-button="unlock" aria-selected="true">Unlock/Create</button>
					<button class="ts-tab" type="button" role="tab" data-sensitive-modal-mode-button="reset" aria-selected="false">Reset passphrase</button>
				</div>
				<form class="ts-sensitive-mode" data-sensitive-mode="unlock" action="javascript:void(0)">
					<label class="ts-list-item ts-field">
						<span class="ts-field__label">Team sensitive data passphrase</span>
						<span class="ts-field__help">Use the same passphrase for Repository, Web, Capacity provider, and Email host secrets.</span>
						<input class="ts-control" name="treeseedSensitivePassphrase" type="password" autocomplete="new-password" required />
					</label>
					<div class="ts-inline-actions">
						<button class="ts-button" type="submit">Unlock sensitive data</button>
						<button class="ts-button-secondary" type="button" data-sensitive-lock-now>Lock</button>
					</div>
				</form>
				<form class="ts-sensitive-mode" data-sensitive-mode="reset" action="javascript:void(0)" hidden>
					<label class="ts-list-item ts-field">
						<span class="ts-field__label">Current passphrase</span>
						<span class="ts-field__help">Reset needs the current passphrase so saved encrypted values can be re-encrypted.</span>
						<input class="ts-control" name="currentPassphrase" type="password" autocomplete="new-password" required />
					</label>
					<label class="ts-list-item ts-field">
						<span class="ts-field__label">New passphrase</span>
						<input class="ts-control" name="newPassphrase" type="password" autocomplete="new-password" required />
					</label>
					<label class="ts-list-item ts-field">
						<span class="ts-field__label">Confirm new passphrase</span>
						<input class="ts-control" name="confirmPassphrase" type="password" autocomplete="new-password" required />
					</label>
					<div class="ts-sensitive-forgot">
						Forgot the current passphrase? Existing encrypted provider values cannot be recovered. Create replacement hosts with a new passphrase.
					</div>
					<div class="ts-inline-actions">
						<button class="ts-button" type="submit">Re-encrypt saved data</button>
					</div>
				</form>
				<p class="ts-subtle" data-sensitive-modal-status role="status"></p>
			</div>
			<aside class="ts-sensitive-dialog__help">
				<strong>Provider values are encrypted in your browser and are not available to TreeSeed.</strong>
				<p>Your passphrase stays in this tab's memory only. It is not saved in local storage, cookies, or project metadata. Refreshing or navigating locks the page again.</p>
				<p>When you save host credentials, the browser stretches your passphrase with Argon2id, then encrypts the values with XSalsa20-Poly1305 authenticated encryption. Each save uses a fresh salt and nonce, and TreeSeed stores only the encrypted envelope.</p>
				<p>Launch and validation actions use short-lived server sessions. The server receives the passphrase only for that unlock request, re-encrypts the provider values for the job/session, and does not return secrets in normal API responses.</p>
			</aside>
		</section>
	</div>
	<script is:inline data-astro-rerun>
		const sensitiveApiWindow = window;
		sensitiveApiWindow.treeseedSensitiveUnlock?.destroy?.();
		const sensitiveStateKey = '__treeseedSensitiveUnlockState';
		const sensitiveState = sensitiveApiWindow[sensitiveStateKey] ??= {
			passphrase: '',
			pendingPassphraseRequests: [],
		};
		const resetHandlers = new Set();
		const cleanups = [];

		function currentUnlockButton() {
			return document.querySelector('[data-sensitive-unlock-button]');
		}

		function currentUnlockLabel() {
			return document.querySelector('[data-sensitive-unlock-label]');
		}

		function currentModal() {
			return document.querySelector('[data-sensitive-modal]');
		}

		function currentStatusElement() {
			return document.querySelector('[data-sensitive-modal-status]');
		}

		function currentModeButtons() {
			return [...document.querySelectorAll('[data-sensitive-modal-mode-button]')];
		}

		function currentModePanels() {
			return [...document.querySelectorAll('[data-sensitive-mode]')];
		}

		function bindSensitiveEvent(target, type, listener, options) {
			if (!target) return;
			target.addEventListener(type, listener, options);
			cleanups.push(() => target.removeEventListener(type, listener, options));
		}

		function currentUnlockForm() {
			return document.querySelector('[data-sensitive-mode="unlock"]');
		}

		function currentResetForm() {
			return document.querySelector('[data-sensitive-mode="reset"]');
		}

		function setSensitiveStatus(message, tone = '') {
			const statusElement = currentStatusElement();
			if (!statusElement) return;
			statusElement.textContent = message;
			statusElement.setAttribute('data-tone', tone);
		}

		function isSensitiveUnlocked() {
			return Boolean(sensitiveState.passphrase);
		}

		function dispatchSensitiveChange() {
			window.dispatchEvent(new CustomEvent('treeseed:sensitive-unlock-change', {
				detail: { unlocked: isSensitiveUnlocked() },
			}));
		}

		function refreshSensitiveUi() {
			const unlocked = isSensitiveUnlocked();
			const unlockButton = currentUnlockButton();
			const unlockLabel = currentUnlockLabel();
			document.documentElement.dataset.sensitiveUnlocked = unlocked ? 'true' : 'false';
			unlockButton?.setAttribute('data-state', unlocked ? 'unlocked' : 'locked');
			if (unlockLabel) unlockLabel.textContent = unlocked ? 'Sensitive data unlocked' : 'Unlock sensitive data';
			for (const element of document.querySelectorAll('[data-sensitive-lock]')) {
				if ('disabled' in element) element.disabled = !unlocked;
				element.setAttribute('aria-disabled', unlocked ? 'false' : 'true');
				element.closest('[data-sensitive-lock-wrap]')?.classList.toggle('ts-sensitive-locked', !unlocked);
			}
			for (const message of document.querySelectorAll('[data-sensitive-lock-message]')) {
				message.hidden = unlocked;
			}
			dispatchSensitiveChange();
		}

		function selectSensitiveMode(mode) {
			const selected = mode === 'reset' ? 'reset' : 'unlock';
			for (const button of currentModeButtons()) {
				const active = button.getAttribute('data-sensitive-modal-mode-button') === selected;
				button.setAttribute('aria-selected', active ? 'true' : 'false');
				button.setAttribute('aria-current', active ? 'page' : 'false');
			}
			for (const panel of currentModePanels()) {
				panel.hidden = panel.getAttribute('data-sensitive-mode') !== selected;
			}
		}

		function openSensitiveModal(mode = 'unlock') {
			const modal = currentModal();
			selectSensitiveMode(mode);
			modal?.removeAttribute('hidden');
			setSensitiveStatus('');
			setTimeout(() => {
				const input = modal?.querySelector(`[data-sensitive-mode="${mode === 'reset' ? 'reset' : 'unlock'}"] input`);
				input?.focus();
			}, 0);
		}

		function closeSensitiveModal() {
			const modal = currentModal();
			modal?.setAttribute('hidden', '');
			if (!sensitiveState.passphrase) resolvePendingPassphraseRequests(null);
		}

		function resolvePendingPassphraseRequests(passphrase) {
			const requests = sensitiveState.pendingPassphraseRequests.splice(0);
			for (const resolve of requests) resolve(passphrase || null);
		}

		function setPassphrase(passphrase) {
			sensitiveState.passphrase = passphrase;
			refreshSensitiveUi();
			resolvePendingPassphraseRequests(passphrase);
		}

		function clearPagePassphrase() {
			setPassphrase('');
		}

		function handleUnlockSubmit(event) {
			event?.preventDefault?.();
			event?.stopPropagation?.();
			const unlockForm = event?.target?.matches?.('[data-sensitive-mode="unlock"]') ? event.target : currentUnlockForm();
			if (!unlockForm) return false;
			const form = new FormData(unlockForm);
			const passphrase = String(form.get('treeseedSensitivePassphrase') ?? '');
			if (!passphrase) {
				setSensitiveStatus('Enter the team sensitive data passphrase.', 'error');
				return false;
			}
			setPassphrase(passphrase);
			setSensitiveStatus('Sensitive data unlocked for this page.', 'success');
			closeSensitiveModal();
			return false;
		}

		async function handleResetSubmit(event) {
			event?.preventDefault?.();
			event?.stopPropagation?.();
			const resetForm = event?.target?.matches?.('[data-sensitive-mode="reset"]') ? event.target : currentResetForm();
			if (!resetForm) return false;
			const form = new FormData(resetForm);
			const currentPassphrase = String(form.get('currentPassphrase') ?? '');
			const newPassphrase = String(form.get('newPassphrase') ?? '');
			const confirmPassphrase = String(form.get('confirmPassphrase') ?? '');
			if (!currentPassphrase || !newPassphrase) {
				setSensitiveStatus('Enter the current and new passphrases.', 'error');
				return false;
			}
			if (newPassphrase !== confirmPassphrase) {
				setSensitiveStatus('The new passphrases do not match.', 'error');
				return false;
			}
			setSensitiveStatus('Re-encrypting saved sensitive data...');
			try {
				for (const handler of resetHandlers) {
					await handler({ currentPassphrase, newPassphrase });
				}
				setPassphrase(newPassphrase);
				setSensitiveStatus(resetHandlers.size > 0 ? 'Saved sensitive data was re-encrypted.' : 'Passphrase changed for this page.', 'success');
				closeSensitiveModal();
			} catch (error) {
				setSensitiveStatus(error instanceof Error ? error.message : String(error), 'error');
			}
			return false;
		}

		// Keep window.treeseedSensitiveUnlock as the stable page API for market forms.
		sensitiveApiWindow.treeseedSensitiveUnlock = {
			isUnlocked: isSensitiveUnlocked,
			getPassphrase() {
				return sensitiveState.passphrase || null;
			},
			requirePassphrase() {
				if (!sensitiveState.passphrase) openSensitiveModal('unlock');
				return sensitiveState.passphrase || null;
			},
			requestPassphrase() {
				if (sensitiveState.passphrase) return Promise.resolve(sensitiveState.passphrase);
				openSensitiveModal('unlock');
				return new Promise((resolve) => {
					sensitiveState.pendingPassphraseRequests.push(resolve);
				});
			},
			promptPassphrase() {
				setPassphrase('');
				openSensitiveModal('unlock');
				return new Promise((resolve) => {
					sensitiveState.pendingPassphraseRequests.push(resolve);
				});
			},
			open: openSensitiveModal,
			lock() {
				setPassphrase('');
				setSensitiveStatus('Sensitive data is locked.', 'info');
			},
			refresh: refreshSensitiveUi,
			registerResetHandler(handler) {
				resetHandlers.add(handler);
				return () => resetHandlers.delete(handler);
			},
			submitUnlock: handleUnlockSubmit,
			submitReset: handleResetSubmit,
			destroy() {
				clearPagePassphrase();
				for (const cleanup of cleanups.splice(0)) cleanup();
			},
		};

		bindSensitiveEvent(document, 'click', (event) => {
			const target = event.target instanceof Element ? event.target.closest('[data-sensitive-unlock-button]') : null;
			if (!target) return;
			event.preventDefault();
			openSensitiveModal('unlock');
		});
		for (const closeButton of document.querySelectorAll('[data-sensitive-modal-close]')) {
			bindSensitiveEvent(closeButton, 'click', closeSensitiveModal);
		}
		bindSensitiveEvent(document, 'click', (event) => {
			const button = event.target instanceof Element ? event.target.closest('[data-sensitive-modal-mode-button]') : null;
			if (!button) return;
			selectSensitiveMode(button.getAttribute('data-sensitive-modal-mode-button'));
		});
		bindSensitiveEvent(document.querySelector('[data-sensitive-lock-now]'), 'click', () => {
			sensitiveApiWindow.treeseedSensitiveUnlock?.lock();
			closeSensitiveModal();
		});
		bindSensitiveEvent(currentUnlockForm(), 'submit', handleUnlockSubmit);
		bindSensitiveEvent(currentResetForm(), 'submit', handleResetSubmit);
		bindSensitiveEvent(document, 'submit', (event) => {
			const sensitiveForm = event.target?.matches?.('[data-sensitive-mode]') ? event.target : null;
			if (!sensitiveForm) return;
			if (sensitiveForm.getAttribute('data-sensitive-mode') === 'reset') {
				handleResetSubmit(event);
			} else {
				handleUnlockSubmit(event);
			}
		}, true);
		bindSensitiveEvent(document, 'keydown', (event) => {
			const modal = currentModal();
			if (event.key === 'Escape' && !modal?.hasAttribute('hidden')) closeSensitiveModal();
		});
		bindSensitiveEvent(document, 'astro:before-swap', clearPagePassphrase);
		bindSensitiveEvent(window, 'pagehide', clearPagePassphrase);
		refreshSensitiveUi();
	</script>
</>
) : null}
