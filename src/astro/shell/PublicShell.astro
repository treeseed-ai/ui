---
import PublicSingleColumnShell from '../public/PublicSingleColumnShell.astro';
import type { ButtonAction, ShellBrand, ShellNavItem } from '../types.ts';
import type { FeedbackContext, HelpContext } from '../../lib/foundation/contracts.ts';
import type { ThemePreference, TreeseedThemeConfig } from '../../theme/index.ts';

// FeedbackButton, FeedbackDialog, HelpButton, and HelpDrawer are composed through PublicSingleColumnShell.

interface NavGroup {
	label: string;
	items: ShellNavItem[];
}

interface Props {
	title: string;
	description: string;
	currentPath: string;
	appearance: ThemePreference;
	brand: ShellBrand;
	navItems: ShellNavItem[];
	navGroups?: NavGroup[];
	actions?: ButtonAction[];
	showAppearanceControl?: boolean;
	preferServerAppearance?: boolean;
	contentWidth?: 'shell' | 'content';
	themeConfig?: TreeseedThemeConfig;
	helpContext?: HelpContext;
	feedbackContext?: FeedbackContext;
}

const {
	title,
	description,
	currentPath,
	appearance,
	brand,
	navItems,
	navGroups = [],
	actions = [],
	showAppearanceControl = true,
	preferServerAppearance = false,
	themeConfig,
	helpContext,
	feedbackContext,
} = Astro.props as Props;
const flattenedNav = navGroups.length > 0 ? navGroups.flatMap((group) => group.items) : navItems;
---

<PublicSingleColumnShell
	title={title}
	description={description}
	currentPath={currentPath}
	appearance={appearance}
	brand={brand}
	navItems={flattenedNav}
	actions={actions}
	showAppearanceControl={showAppearanceControl}
	preferServerAppearance={preferServerAppearance}
	themeConfig={themeConfig}
	helpContext={helpContext}
	feedbackContext={feedbackContext}
>
	<Fragment slot="actions"><slot name="actions" /></Fragment>
	<slot />
	{Astro.slots.has('footer') ? <Fragment slot="footer"><slot name="footer" /></Fragment> : null}
</PublicSingleColumnShell>
