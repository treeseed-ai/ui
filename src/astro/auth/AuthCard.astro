---
import Panel from '../surface/Panel.astro';
import type { ThemePreference } from '../../theme/types.ts';

interface Props {
	title: string;
	description: string;
	error?: string;
	notice?: string;
	appearance: ThemePreference;
	appearanceLabel?: string;
	showAppearance?: boolean;
}

const {
	title,
	description,
	error = '',
	notice = '',
} = Astro.props as Props;
---

<Panel class="auth-card">
	<aside class="auth-card__brand" aria-label="TreeSeed">
		<a class="auth-brand" href="/" aria-label="TreeSeed home">
			<span class="auth-brand__mark">
				<img src="/logo.svg" alt="" width="60" height="60" loading="eager" />
			</span>
			<span class="auth-brand__text">
				<span class="auth-brand__name">TreeSeed Platform</span>
				<span class="auth-brand__tag">Simple controls</span>
			</span>
		</a>
		{Astro.slots.has('sidebarLinks') ? (
			<nav class="auth-card__links" aria-label="Account links">
				<slot name="sidebarLinks" />
			</nav>
		) : null}
	</aside>
	<div class="auth-card__main">
		<header class="auth-card__header">
			<h1>{title}</h1>
			<p>{description}</p>
		</header>
		{error ? <div class="auth-alert" data-tone="danger" role="alert">{error}</div> : null}
		{notice ? <div class="auth-alert" data-tone="success" role="status">{notice}</div> : null}
		{Astro.slots.has('default') ? (
			<div class="auth-card__body">
				<slot />
			</div>
		) : null}
	</div>
</Panel>
