---
import '../../styles/auth.css';
import ShellFrame from '../shell/ShellFrame.astro';
import SiteUserControls from '../shell/SiteUserControls.astro';
import DevWatchReload from '../core/DevWatchReload.astro';
import type { FeedbackContext, HelpContext } from '../../lib/foundation/contracts.ts';
import type { ThemePreference } from '../../theme/types.ts';

// FeedbackButton, FeedbackDialog, HelpButton, and HelpDrawer are composed through SiteUserControls and ShellFrame.

interface Props {
	title: string;
	description?: string;
	appearance: ThemePreference;
	helpContext?: HelpContext;
	feedbackContext?: FeedbackContext;
}

const {
	title,
	description = 'TreeSeed account access.',
	appearance,
	helpContext,
	feedbackContext,
} = Astro.props as Props;
const feedbackDialogId = 'auth-shell-feedback';
const helpDrawerId = 'auth-shell-help';
const authLinks = [
	{ label: 'Home', href: '/' },
	{ label: 'Market', href: '/market/' },
	{ label: 'Knowledge', href: '/knowledge/' },
];
---

<ShellFrame
	title={title}
	description={description}
	appearance={appearance}
	helpContext={helpContext}
	feedbackContext={feedbackContext}
	helpDrawerId={helpDrawerId}
	feedbackDialogId={feedbackDialogId}
	bodyClass="auth-shell-body"
>
	<div class="auth-shell-frame">
		<header class="auth-shell-bar">
			<a class="auth-shell-bar__brand" href="/" aria-label="TreeSeed home">
				<span class="auth-shell-bar__mark">T</span>
				<span>
					<strong>TreeSeed</strong>
					<small>Simple controls</small>
				</span>
			</a>
			<SiteUserControls
				items={authLinks}
				currentPath={Astro.url.pathname}
				appearance={appearance}
				helpContext={helpContext}
				feedbackContext={feedbackContext}
				helpDrawerId={helpDrawerId}
				feedbackDialogId={feedbackDialogId}
			/>
		</header>
		<main class="auth-shell" id="main-content">
			<slot />
		</main>
	</div>
	<DevWatchReload slot="bodyEnd" />
	<script is:inline data-astro-rerun slot="bodyEnd">
		(() => {
			const storagePrefix = 'treeseed:auth-form:';
			const hasError = Boolean(document.querySelector('.auth-alert[data-tone="danger"]'));

			function storageKey(form) {
				const action = form.getAttribute('action') || location.pathname;
				return `${storagePrefix}${new URL(action, location.origin).pathname}`;
			}

			function restoreForm(form) {
				if (!hasError) {
					sessionStorage.removeItem(storageKey(form));
					return;
				}
				let values = null;
				try {
					values = JSON.parse(sessionStorage.getItem(storageKey(form)) || 'null');
				} catch {
					values = null;
				}
				if (!values || typeof values !== 'object') return;
				for (const field of form.elements) {
					if (!field?.name || field.type === 'hidden' || field.type === 'submit') continue;
					const value = values[field.name];
					if (typeof value !== 'string') continue;
					if (field.type === 'checkbox' || field.type === 'radio') {
						field.checked = value === field.value;
					} else {
						field.value = value;
					}
				}
			}

			for (const form of document.querySelectorAll('form.auth-form')) {
				restoreForm(form);
				form.addEventListener('submit', () => {
					const values = {};
					for (const field of form.elements) {
						if (!field?.name || field.type === 'hidden' || field.type === 'submit') continue;
						values[field.name] = field.type === 'checkbox' || field.type === 'radio'
							? (field.checked ? field.value : '')
							: field.value;
					}
					sessionStorage.setItem(storageKey(form), JSON.stringify(values));
				});
			}
		})();
	</script>
</ShellFrame>
