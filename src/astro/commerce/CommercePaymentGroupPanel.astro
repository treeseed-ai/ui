---
interface Props {
	title?: string;
}
const { title = 'Payment groups' } = Astro.props as Props;
---
<section class="ts-commerce-panel">
	<div class="ts-commerce-panel-header">
		<div>
			<p class="ts-commerce-eyebrow">Grouped vendor checkout</p>
			<h2>{title}</h2>
		</div>
		<slot name="actions" />
	</div>
	<slot />
</section>
