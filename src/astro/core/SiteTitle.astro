---
import { SITE } from '../../utils/seo.ts';

const { siteTitleHref = '/' } = Astro.props as { siteTitleHref?: string };
---

<a href={siteTitleHref} class="site-header-custom sl-flex" aria-label={SITE.name}>
	<img src={SITE.logo.src} alt={SITE.logo.alt} class="site-header-logo" />
	<span class="site-header-copy">
		<span class="site-header-name" translate="no">{SITE.name}</span>
		<span class="site-header-statement">{SITE.statement}</span>
	</span>
</a>

<style>
	@layer starlight.core {
		.site-header-custom {
			align-items: center;
			gap: 0.85rem;
			color: var(--sl-color-white);
			text-decoration: none;
			min-width: 0;
		}

		.site-header-logo {
			width: 3.75rem;
			height: 3.75rem;
			object-fit: contain;
			flex: 0 0 auto;
		}

		.site-header-copy {
			display: grid;
			min-width: 0;
		}

		.site-header-name {
			font-size: var(--sl-text-h4);
			font-weight: 600;
			line-height: 1.1;
		}

		.site-header-statement {
			font-size: var(--sl-text-xs);
			color: var(--sl-color-gray-3);
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}
	}
</style>
