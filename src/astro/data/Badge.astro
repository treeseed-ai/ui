---
import type { Tone } from '../types.ts';

interface Props {
	tone?: Tone;
	size?: 'sm' | 'md';
	class?: string;
}

const {
	tone = 'default',
	size = 'md',
	class: className,
} = Astro.props as Props;
---

<span class:list={['ts-badge', className]} data-tone={tone} data-size={size}>
	<slot />
</span>
