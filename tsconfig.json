{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@treeseed/ui": ["src/index.ts"],
      "@treeseed/ui/react": ["src/react.ts"],
      "@treeseed/ui/theme": ["src/theme/index.ts"],
      "@treeseed/ui/*": ["src/*"]
    }
  },
  "include": [
    "src",
    "sandbox/src",
    "tests",
    "astro.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
