{entry.id === 'launch-requirement-summary' ? <LaunchRequirementSummary templates={templates} defaultTemplateId="template:monitoring-console" /> : null}
{entry.id === 'plain-table' ? <PlainTable columns={tableColumns} rows={tableRows} interactive pageSize={2} /> : null}
{entry.id === 'project-control-nav' ? <ProjectControlNav projectId="project-42" current="deploy" /> : null}
{entry.id === 'related-content-creator' ? <RelatedContentCreator projectId="project-42" parentCollection="objectives" parentSlug="market-launch" parentTitle="Market launch readiness" actions={[{ collection: 'questions', label: 'Question' }, { collection: 'decisions', label: 'Decision' }]} /> : null}
