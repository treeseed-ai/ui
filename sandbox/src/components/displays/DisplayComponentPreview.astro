{entry.id === 'work-content-nav' ? <WorkContentNav current="objectives" /> : null}
{entry.id === 'capacity-diagnostics-panel' ? <CapacityDiagnosticsPanel capacity={capacity} diagnostics={diagnostics} /> : null}
{entry.id === 'deployment-timeline' ? <DeploymentTimeline items={timelineItems} /> : null}
{entry.id === 'governance-decision-panel' ? <GovernanceDecisionPanel approval={approval} /> : null}
{entry.id === 'governance-policy-summary' ? <GovernancePolicySummary policies={policies} constraints={constraints} /> : null}
{entry.id === 'knowledge-artifact-card' ? <KnowledgeArtifactCard artifact={artifact} /> : null}
{entry.id === 'operational-timeline' ? <OperationalTimeline events={events} phases={phases} /> : null}
{entry.id === 'repository-context-panel' ? <RepositoryContextPanel repositories={repositories} /> : null}
{entry.id === 'seed-operations-panel' ? <SeedOperationsPanel seeds={seeds} /> : null}
{entry.id === 'worker-queue-panel' ? <WorkerQueuePanel workers={workers} /> : null}
{entry.id === 'sensitive-data-unlock' ? <div><SensitiveDataUnlock part="button" /><SensitiveDataUnlock part="modal" /></div> : null}
