{entry.id === 'commons-vote-summary' ? <CommonsVoteSummary support={entry.defaultProps.support as number} object={entry.defaultProps.object as number} abstain={entry.defaultProps.abstain as number} backers={entry.defaultProps.backers as number} /> : null}
