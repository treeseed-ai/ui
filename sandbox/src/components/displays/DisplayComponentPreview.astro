{entry.id === 'provider-button-list' ? <ProviderButtonList providers={[{ id: 'github' }, { id: 'google' }]} returnTo="/app/" /> : null}
{entry.id === 'content-status-legend' ? <ContentStatusLegend /> : null}
{entry.id === 'status-badge' ? <div class="primitive-inline"><ContentStatusBadge status="live" /><ContentStatusBadge status="in progress" /><ContentStatusBadge status="planned" /></div> : null}
{entry.id === 'dev-watch-reload' ? <div><p class="ts-subtle">Development reload script is mounted below for local sessions.</p><DevWatchReload /></div> : null}
