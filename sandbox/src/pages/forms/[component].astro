---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../../../src/astro/forms/Button.astro';
import Field from '../../../../src/astro/forms/Field.astro';
import FormActions from '../../../../src/astro/forms/FormActions.astro';
import MarkdownField from '../../../../src/astro/forms/MarkdownField.astro';
import PasswordMeter from '../../../../src/astro/forms/PasswordMeter.astro';
import RadioGroup from '../../../../src/astro/forms/RadioGroup.astro';
import Select from '../../../../src/astro/forms/Select.astro';
import TextInput from '../../../../src/astro/forms/TextInput.astro';
import Textarea from '../../../../src/astro/forms/Textarea.astro';
import ThemeMenu from '../../../../src/astro/theme/ThemeMenu.astro';
import ThemeSelector from '../../../../src/astro/theme/ThemeSelector.astro';
import DynamicPieAllocationHarness from '../../components/forms/DynamicPieAllocationHarness.tsx';
import ReactFormControlHarness from '../../components/forms/ReactFormControlHarness.tsx';
import RichMarkdownEditorHarness from '../../components/forms/RichMarkdownEditorHarness.tsx';
import { defineTreeseedTheme } from '../../../../src/theme/index.ts';
import { findComponent, formComponents, type ComponentCatalogEntry } from '../../lib/component-catalog.ts';

export const prerender = true;

export function getStaticPaths() {
  return formComponents.map((entry) => ({
    params: { component: entry.id },
    props: { entry },
  }));
}

const props = Astro.props as { entry?: ComponentCatalogEntry };
const entry = props.entry ?? findComponent('form', Astro.params.component) ?? formComponents[0];
const themeConfig = defineTreeseedTheme({
  schemeDirectories: ['treeseed.color-schemes'],
  defaultScheme: 'fern',
  defaultMode: 'system',
  cwd: process.cwd(),
});
const configJson = JSON.stringify({
  packageEntry: entry.packageEntry,
  defaultProps: entry.defaultProps,
  configurableProps: entry.configurableProps,
}, null, 2);
const stateJson = JSON.stringify(entry.stateShape ?? {}, null, 2);
---

<BaseLayout title={`TreeSeed UI ${entry.name}`}>
  <main class="catalog-shell catalog-page" data-testid="component-page" data-component={entry.id} data-kind="form">
    <header class="catalog-page-header">
      <div>
        <p class="sandbox-eyebrow">Form Elements / {entry.category}</p>
        <h1>{entry.name}</h1>
        <p>{entry.description}</p>
      </div>
      <a class="ts-button" data-variant="secondary" href="/">All components</a>
    </header>

    {entry.runtime === 'react' && entry.id === 'dynamic-pie-allocation' ? <DynamicPieAllocationHarness client:load /> : null}
    {entry.runtime === 'react' && entry.id === 'rich-markdown-editor' ? <RichMarkdownEditorHarness client:only="react" /> : null}
    {entry.runtime === 'react' && ['checkbox-field', 'select-field', 'text-field'].includes(entry.id) ? (
      <ReactFormControlHarness
        client:load
        componentId={entry.id as 'checkbox-field' | 'select-field' | 'text-field'}
        componentName={entry.name}
        intendedSize={entry.intendedSize}
      />
    ) : null}

    {entry.runtime === 'astro' ? (
      <form class="catalog-form-harness" data-catalog-form data-redact-password={entry.id === 'password-meter' ? 'true' : undefined}>
        <section class:list={['catalog-preview', `catalog-preview--${entry.intendedSize}`]} aria-label={`${entry.name} preview`}>
          <span class="catalog-preview__label">Component frame</span>
          <div class="catalog-preview__stage">
            {entry.id === 'button' ? (
              <div class="primitive-inline">
                <Button type="submit">Submit primary</Button>
                <Button variant="secondary">Secondary</Button>
                <Button variant="ghost">Ghost</Button>
                <Button variant="danger">Danger</Button>
                <Button disabled>Disabled</Button>
              </div>
            ) : null}
            {entry.id === 'field' ? (
              <>
                <Field label="Project name" name="project_name" help="Short labels work best in TreeSeed navigation.">
                  <TextInput name="project_name" value="Monitoring Console" />
                </Field>
                <FormActions><Button type="submit">Submit field</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'form-actions' ? (
              <FormActions align="between">
                <Button variant="secondary">Save draft</Button>
                <Button type="submit">Submit</Button>
              </FormActions>
            ) : null}
            {entry.id === 'markdown-field' ? (
              <>
                <MarkdownField
                  label="Decision body"
                  name="decision_body"
                  rows={8}
                  required
                  help="Write Markdown and switch to preview to render the formatted output."
                  value={'# Launch decision\n\nUse **guarded rollout** with:\n\n- health checks\n- rollback notes\n- owner signoff'}
                />
                <FormActions><Button type="submit">Submit markdown</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'password-meter' ? (
              <>
                <Field label="Password" name="password">
                  <TextInput name="password" id="password-preview" type="password" value="TreeSeed-Preview-123!" data-ts-password-input />
                </Field>
                <PasswordMeter inputId="password-preview" />
                <FormActions><Button type="submit">Submit password</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'radio-group' ? (
              <>
                <RadioGroup name="strategy" legend="Release strategy" value="guarded" required options={[{ label: 'Guarded', value: 'guarded', help: 'Run checks first.' }, { label: 'Fast path', value: 'fast', help: 'Low blast radius changes.' }]} />
                <FormActions><Button type="submit">Submit strategy</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'select' ? (
              <>
                <Field label="Environment" name="environment">
                  <Select name="environment" value="production" required options={[{ label: 'Production', value: 'production' }, { label: 'Staging', value: 'staging' }, { label: 'Development', value: 'development' }]} />
                </Field>
                <FormActions><Button type="submit">Submit environment</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'text-input' ? (
              <>
                <Field label="Project" name="project">
                  <TextInput name="project" value="Monitoring Console" required />
                </Field>
                <FormActions><Button type="submit">Submit project</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'textarea' ? (
              <>
                <Field label="Notes" name="notes">
                  <Textarea name="notes" rows={5} value="Watch queue depth and deployment drift before widening traffic." />
                </Field>
                <FormActions><Button type="submit">Submit notes</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'theme-menu' ? (
              <>
                <ThemeMenu selectedScheme="fern" selectedMode="system" themeConfig={themeConfig} />
                <FormActions><Button type="submit">Submit appearance</Button></FormActions>
              </>
            ) : null}
            {entry.id === 'theme-selector' ? (
              <>
                <ThemeSelector selectedScheme="fern" selectedMode="system" themeConfig={themeConfig} compact={false} includeHiddenFields />
                <FormActions><Button type="submit">Submit appearance</Button></FormActions>
              </>
            ) : null}
          </div>
        </section>

        <div class="catalog-info-grid">
          <section class="catalog-debug" aria-label="Current State">
            <h2>Current State</h2>
            <pre data-current-state>{stateJson}</pre>
          </section>
          <section class="catalog-debug" aria-label="Submission">
            <h2>Submission</h2>
            <pre data-submission-state>null</pre>
          </section>
        </div>
      </form>
    ) : null}

    <aside class="catalog-info-grid" aria-label="Component metadata">
      <section class="catalog-debug" aria-label="Configuration Options">
        <h2>Configuration Options</h2>
        <pre>{configJson}</pre>
      </section>
      <section class="catalog-debug" aria-label="Defaults">
        <h2>Defaults</h2>
        <pre>{JSON.stringify(entry.defaultProps, null, 2)}</pre>
      </section>
    </aside>
  </main>
</BaseLayout>

<script>
  const redactValue = (
    key: string,
    value: FormDataEntryValue,
    redactPassword: boolean
  ) => {
    if (!redactPassword) return value;
    return key.toLowerCase().includes('password') ? '[redacted]' : value;
  };

  const readFormState = (form: HTMLFormElement) => {
    const redactPassword = form.dataset.redactPassword === 'true';
    const data: Record<string, FormDataEntryValue | string | undefined> = {};
    new FormData(form).forEach((value, key) => {
      data[key] = redactValue(key, value, redactPassword);
    });
    if (form.querySelector('[data-ts-theme-selector]') || form.querySelector('[data-ts-theme-menu]')) {
      data.colorScheme = document.documentElement.dataset.tsScheme;
      data.themeMode = document.documentElement.dataset.tsModeSource === 'system' ? 'system' : document.documentElement.dataset.tsMode;
    }
    return data;
  };

  const syncForm = (form: HTMLFormElement) => {
    const current = form.querySelector('[data-current-state]');
    if (current) current.textContent = JSON.stringify(readFormState(form), null, 2);
  };

  document.querySelectorAll('[data-catalog-form]').forEach((element) => {
    if (!(element instanceof HTMLFormElement)) return;
    const form = element;
    syncForm(form);
    form.addEventListener('input', () => syncForm(form));
    form.addEventListener('change', () => syncForm(form));
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      syncForm(form);
      const submission = form.querySelector('[data-submission-state]');
      if (submission) submission.textContent = JSON.stringify(readFormState(form), null, 2);
    });
    window.addEventListener('treeseed:theme-change', () => syncForm(form));
  });
</script>
